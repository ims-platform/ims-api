{
  "compilerOptions": {
    "target": "esnext",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "esModuleInterop": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "@/*": ["./src/*"],
      "@institute/*": ["./src/modules/institute/*"],
      "@routes/*": ["./src/modules/routes/*"]
    }
  },
  "include": ["src/**/*"]
}
